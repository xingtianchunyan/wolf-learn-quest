/**
 * @fileoverview 游戏状态管理Hook
 * 提供统一的游戏状态管理功能，包括阶段管理、玩家状态、技能使用等
 *
 * @author SOLO Coding
 * @version 1.0.0
 * @since 2024-12-19
 */

import { useState, useEffect, useCallback, useRef } from 'react';
import { createLogger } from '@/lib/logger';
import {
  globalGamePhaseManager,
  globalRoleStatusManager,
  globalSkillUsageManager,
  globalStateHistory,
} from '@/utils/common/stateHelpers';
import { GamePhase, RoleStatus, SkillType } from '@/types/skillSystem.types';
import { useWebSocket } from '@/hooks/useWebSocket';
import { useAuth } from '@/hooks/useAuth';

const logger = createLogger('use-game-state');

/**
 * 游戏状态接口
 */
export interface GameState {
  /** 当前游戏阶段 */
  currentPhase: GamePhase;
  /** 阶段开始时间 */
  phaseStartTime: number;
  /** 阶段持续时间 */
  phaseDuration: number;
  /** 是否正在切换阶段 */
  isTransitioning: boolean;
  /** 玩家状态映射 */
  playerStatuses: Map<string, RoleStatus>;
  /** 当前用户状态 */
  currentUserStatus: RoleStatus;
  /** 技能冷却状态 */
  skillCooldowns: Map<SkillType, number>;
  /** 游戏是否活跃 */
  isGameActive: boolean;
  /** 游戏房间ID */
  roomId?: string;
  /** 在线玩家数量 */
  onlinePlayerCount: number;
  /** 游戏配置 */
  gameConfig: GameConfig;
}

/**
 * 游戏配置接口
 */
export interface GameConfig {
  /** 白天阶段时长（秒） */
  dayDuration: number;
  /** 夜晚阶段时长（秒） */
  nightDuration: number;
  /** 讨论阶段时长（秒） */
  discussionDuration: number;
  /** 投票阶段时长（秒） */
  votingDuration: number;
  /** 最大玩家数 */
  maxPlayers: number;
  /** 最小玩家数 */
  minPlayers: number;
  /** 是否允许观众 */
  allowSpectators: boolean;
  /** 技能冷却时间配置 */
  skillCooldowns: Record<SkillType, number>;
}

/**
 * 游戏状态操作接口
 */
export interface GameStateActions {
  /** 切换游戏阶段 */
  transitionToPhase: (phase: GamePhase, reason?: string) => Promise<void>;
  /** 更新玩家状态 */
  updatePlayerStatus: (
    userId: string,
    status: RoleStatus,
    reason?: string
  ) => void;
  /** 使用技能 */
  useSkill: (skillType: SkillType, targetId?: string) => Promise<boolean>;
  /** 检查技能是否可用 */
  canUseSkill: (skillType: SkillType) => boolean;
  /** 获取技能冷却剩余时间 */
  getSkillCooldown: (skillType: SkillType) => number;
  /** 加入游戏房间 */
  joinRoom: (roomId: string) => Promise<void>;
  /** 离开游戏房间 */
  leaveRoom: () => Promise<void>;
  /** 重置游戏状态 */
  resetGameState: () => void;
  /** 同步服务器状态 */
  syncWithServer: () => Promise<void>;
}

/**
 * 默认游戏配置
 */
const DEFAULT_GAME_CONFIG: GameConfig = {
  dayDuration: 300, // 5分钟
  nightDuration: 180, // 3分钟
  discussionDuration: 120, // 2分钟
  votingDuration: 60, // 1分钟
  maxPlayers: 12,
  minPlayers: 6,
  allowSpectators: true,
  skillCooldowns: {
    [SkillType.INVESTIGATE]: 0,
    [SkillType.PROTECT]: 0,
    [SkillType.KILL]: 0,
    [SkillType.VOTE]: 0,
    [SkillType.SPECIAL]: 30000, // 30秒
  },
};

/**
 * 游戏状态管理Hook
 * @param roomId - 游戏房间ID
 * @param config - 游戏配置
 * @returns 游戏状态和操作函数
 */
export function useGameState(
  roomId?: string,
  config: Partial<GameConfig> = {}
): [GameState, GameStateActions] {
  const { user } = useAuth();
  const { socket, isConnected, emit, on, off } = useWebSocket();

  const [gameState, setGameState] = useState<GameState>({
    currentPhase: 'day',
    phaseStartTime: Date.now(),
    phaseDuration: 0,
    isTransitioning: false,
    playerStatuses: new Map(),
    currentUserStatus: RoleStatus.NORMAL,
    skillCooldowns: new Map(),
    isGameActive: false,
    roomId,
    onlinePlayerCount: 0,
    gameConfig: { ...DEFAULT_GAME_CONFIG, ...config },
  });

  const phaseTimerRef = useRef<NodeJS.Timeout>();
  const syncIntervalRef = useRef<NodeJS.Timeout>();

  /**
   * 更新游戏状态
   */
  const updateGameState = useCallback((updates: Partial<GameState>) => {
    setGameState(prev => ({ ...prev, ...updates }));
  }, []);

  /**
   * 切换游戏阶段
   */
  const transitionToPhase = useCallback(
    async (phase: GamePhase, reason?: string) => {
      if (!isConnected || gameState.isTransitioning) {
        logger.warn('无法切换阶段', {
          isConnected,
          isTransitioning: gameState.isTransitioning,
        });
        return;
      }

      try {
        updateGameState({ isTransitioning: true });

        // 检查是否可以切换到目标阶段
        if (!globalGamePhaseManager.canTransitionTo(phase)) {
          logger.warn('无效的阶段切换', {
            from: gameState.currentPhase,
            to: phase,
          });
          return;
        }

        // 发送阶段切换请求到服务器
        await emit('game:phase:transition', {
          roomId: gameState.roomId,
          targetPhase: phase,
          reason,
          timestamp: Date.now(),
        });

        // 更新本地状态
        globalGamePhaseManager.setPhase(phase, user?.id, reason);

        const now = Date.now();
        updateGameState({
          currentPhase: phase,
          phaseStartTime: now,
          phaseDuration: 0,
          isTransitioning: false,
        });

        logger.info('阶段切换成功', { phase, reason });
      } catch (error) {
        logger.error('阶段切换失败', { error, phase, reason });
        updateGameState({ isTransitioning: false });
      }
    },
    [
      isConnected,
      gameState.isTransitioning,
      gameState.currentPhase,
      gameState.roomId,
      emit,
      user?.id,
      updateGameState,
    ]
  );

  /**
   * 更新玩家状态
   */
  const updatePlayerStatus = useCallback(
    (userId: string, status: RoleStatus, reason?: string) => {
      globalRoleStatusManager.setStatus(userId, status, user?.id, reason);

      const newPlayerStatuses = new Map(gameState.playerStatuses);
      newPlayerStatuses.set(userId, status);

      updateGameState({
        playerStatuses: newPlayerStatuses,
        currentUserStatus:
          userId === user?.id ? status : gameState.currentUserStatus,
      });

      // 同步到服务器
      if (isConnected && gameState.roomId) {
        emit('game:player:status:update', {
          roomId: gameState.roomId,
          userId,
          status,
          reason,
          timestamp: Date.now(),
        });
      }

      logger.info('玩家状态更新', { userId, status, reason });
    },
    [
      gameState.playerStatuses,
      gameState.currentUserStatus,
      gameState.roomId,
      user?.id,
      isConnected,
      emit,
      updateGameState,
    ]
  );

  /**
   * 使用技能
   */
  const useSkill = useCallback(
    async (skillType: SkillType, targetId?: string): Promise<boolean> => {
      if (!user || !isConnected || !gameState.roomId) {
        logger.warn('无法使用技能', {
          hasUser: !!user,
          isConnected,
          hasRoomId: !!gameState.roomId,
        });
        return false;
      }

      // 检查技能是否在冷却中
      if (globalSkillUsageManager.isSkillOnCooldown(user.id, skillType)) {
        const remaining = globalSkillUsageManager.getSkillCooldownRemaining(
          user.id,
          skillType
        );
        logger.warn('技能在冷却中', { skillType, remaining });
        return false;
      }

      try {
        // 发送技能使用请求到服务器
        const result = await emit('game:skill:use', {
          roomId: gameState.roomId,
          userId: user.id,
          skillType,
          targetId,
          timestamp: Date.now(),
        });

        if (result.success) {
          // 记录技能使用
          const cooldownDuration =
            gameState.gameConfig.skillCooldowns[skillType] || 0;
          globalSkillUsageManager.recordSkillUsage(
            user.id,
            skillType,
            targetId,
            cooldownDuration
          );

          // 更新冷却状态
          const newCooldowns = new Map(gameState.skillCooldowns);
          if (cooldownDuration > 0) {
            newCooldowns.set(skillType, Date.now() + cooldownDuration);
          }
          updateGameState({ skillCooldowns: newCooldowns });

          logger.info('技能使用成功', {
            skillType,
            targetId,
            cooldownDuration,
          });
          return true;
        } else {
          logger.warn('技能使用失败', {
            skillType,
            targetId,
            error: result.error,
          });
          return false;
        }
      } catch (error) {
        logger.error('技能使用异常', { error, skillType, targetId });
        return false;
      }
    },
    [
      user,
      isConnected,
      gameState.roomId,
      gameState.gameConfig.skillCooldowns,
      gameState.skillCooldowns,
      emit,
      updateGameState,
    ]
  );

  /**
   * 检查技能是否可用
   */
  const canUseSkill = useCallback(
    (skillType: SkillType): boolean => {
      if (!user) return false;
      return !globalSkillUsageManager.isSkillOnCooldown(user.id, skillType);
    },
    [user]
  );

  /**
   * 获取技能冷却剩余时间
   */
  const getSkillCooldown = useCallback(
    (skillType: SkillType): number => {
      if (!user) return 0;
      return globalSkillUsageManager.getSkillCooldownRemaining(
        user.id,
        skillType
      );
    },
    [user]
  );

  /**
   * 加入游戏房间
   */
  const joinRoom = useCallback(
    async (newRoomId: string) => {
      if (!isConnected) {
        logger.warn('WebSocket未连接，无法加入房间');
        return;
      }

      try {
        const result = await emit('game:room:join', {
          roomId: newRoomId,
          userId: user?.id,
        });

        if (result.success) {
          updateGameState({
            roomId: newRoomId,
            isGameActive: true,
            onlinePlayerCount: result.playerCount || 0,
          });
          logger.info('成功加入游戏房间', { roomId: newRoomId });
        } else {
          logger.error('加入游戏房间失败', {
            roomId: newRoomId,
            error: result.error,
          });
        }
      } catch (error) {
        logger.error('加入游戏房间异常', { error, roomId: newRoomId });
      }
    },
    [isConnected, user?.id, emit, updateGameState]
  );

  /**
   * 离开游戏房间
   */
  const leaveRoom = useCallback(async () => {
    if (!isConnected || !gameState.roomId) return;

    try {
      await emit('game:room:leave', {
        roomId: gameState.roomId,
        userId: user?.id,
      });

      updateGameState({
        roomId: undefined,
        isGameActive: false,
        onlinePlayerCount: 0,
      });

      logger.info('成功离开游戏房间', { roomId: gameState.roomId });
    } catch (error) {
      logger.error('离开游戏房间异常', { error, roomId: gameState.roomId });
    }
  }, [isConnected, gameState.roomId, user?.id, emit, updateGameState]);

  /**
   * 重置游戏状态
   */
  const resetGameState = useCallback(() => {
    globalStateHistory.clearHistory();

    updateGameState({
      currentPhase: 'day',
      phaseStartTime: Date.now(),
      phaseDuration: 0,
      isTransitioning: false,
      playerStatuses: new Map(),
      currentUserStatus: RoleStatus.NORMAL,
      skillCooldowns: new Map(),
      isGameActive: false,
      onlinePlayerCount: 0,
    });

    logger.info('游戏状态已重置');
  }, [updateGameState]);

  /**
   * 同步服务器状态
   */
  const syncWithServer = useCallback(async () => {
    if (!isConnected || !gameState.roomId) return;

    try {
      const serverState = await emit('game:state:sync', {
        roomId: gameState.roomId,
      });

      if (serverState.success) {
        updateGameState({
          currentPhase: serverState.data.currentPhase,
          phaseStartTime: serverState.data.phaseStartTime,
          playerStatuses: new Map(
            Object.entries(serverState.data.playerStatuses)
          ),
          onlinePlayerCount: serverState.data.onlinePlayerCount,
          isGameActive: serverState.data.isGameActive,
        });

        logger.debug('状态同步成功', { serverState: serverState.data });
      }
    } catch (error) {
      logger.error('状态同步失败', { error });
    }
  }, [isConnected, gameState.roomId, emit, updateGameState]);

  /**
   * 设置WebSocket事件监听
   */
  useEffect(() => {
    if (!isConnected) return;

    // 监听阶段变化
    const handlePhaseChange = (data: {
      phase: GamePhase;
      startTime: number;
      reason?: string;
    }) => {
      globalGamePhaseManager.setPhase(data.phase, 'server', data.reason);
      updateGameState({
        currentPhase: data.phase,
        phaseStartTime: data.startTime,
        phaseDuration: 0,
        isTransitioning: false,
      });
      logger.info('收到阶段变化事件', data);
    };

    // 监听玩家状态变化
    const handlePlayerStatusChange = (data: {
      userId: string;
      status: RoleStatus;
      reason?: string;
    }) => {
      globalRoleStatusManager.setStatus(
        data.userId,
        data.status,
        'server',
        data.reason
      );

      const newPlayerStatuses = new Map(gameState.playerStatuses);
      newPlayerStatuses.set(data.userId, data.status);

      updateGameState({
        playerStatuses: newPlayerStatuses,
        currentUserStatus:
          data.userId === user?.id ? data.status : gameState.currentUserStatus,
      });

      logger.info('收到玩家状态变化事件', data);
    };

    // 监听在线人数变化
    const handlePlayerCountChange = (data: { count: number }) => {
      updateGameState({ onlinePlayerCount: data.count });
    };

    // 监听游戏结束
    const handleGameEnd = (data: { reason: string; winner?: string }) => {
      updateGameState({ isGameActive: false });
      logger.info('游戏结束', data);
    };

    on('game:phase:changed', handlePhaseChange);
    on('game:player:status:changed', handlePlayerStatusChange);
    on('game:player:count:changed', handlePlayerCountChange);
    on('game:ended', handleGameEnd);

    return () => {
      off('game:phase:changed', handlePhaseChange);
      off('game:player:status:changed', handlePlayerStatusChange);
      off('game:player:count:changed', handlePlayerCountChange);
      off('game:ended', handleGameEnd);
    };
  }, [
    isConnected,
    gameState.playerStatuses,
    gameState.currentUserStatus,
    user?.id,
    on,
    off,
    updateGameState,
  ]);

  /**
   * 阶段计时器
   */
  useEffect(() => {
    if (phaseTimerRef.current) {
      clearInterval(phaseTimerRef.current);
    }

    if (gameState.isGameActive) {
      phaseTimerRef.current = setInterval(() => {
        const now = Date.now();
        const duration = now - gameState.phaseStartTime;
        updateGameState({ phaseDuration: duration });
      }, 1000);
    }

    return () => {
      if (phaseTimerRef.current) {
        clearInterval(phaseTimerRef.current);
      }
    };
  }, [gameState.isGameActive, gameState.phaseStartTime, updateGameState]);

  /**
   * 定期同步状态
   */
  useEffect(() => {
    if (syncIntervalRef.current) {
      clearInterval(syncIntervalRef.current);
    }

    if (gameState.isGameActive && gameState.roomId) {
      syncIntervalRef.current = setInterval(() => {
        syncWithServer();
      }, 30000); // 每30秒同步一次
    }

    return () => {
      if (syncIntervalRef.current) {
        clearInterval(syncIntervalRef.current);
      }
    };
  }, [gameState.isGameActive, gameState.roomId, syncWithServer]);

  /**
   * 组件卸载时清理
   */
  useEffect(() => {
    return () => {
      if (phaseTimerRef.current) {
        clearInterval(phaseTimerRef.current);
      }
      if (syncIntervalRef.current) {
        clearInterval(syncIntervalRef.current);
      }
    };
  }, []);

  const actions: GameStateActions = {
    transitionToPhase,
    updatePlayerStatus,
    useSkill,
    canUseSkill,
    getSkillCooldown,
    joinRoom,
    leaveRoom,
    resetGameState,
    syncWithServer,
  };

  return [gameState, actions];
}
