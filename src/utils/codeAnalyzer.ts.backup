/**
 * 文件级注释：代码分析工具
 * 提供代码重复检测和优化建议功能
 */

import * as fs from 'fs';
import * as path from 'path';

/**
 * 代码块接口
 */
export interface CodeBlock {
  content: string;
  file: string;
  startLine: number;
  endLine: number;
  hash: string;
}

/**
 * 重复代码检测结果接口
 */
export interface DuplicateCodeResult {
  blocks: CodeBlock[];
  similarity: number;
  suggestions: string[];
}

/**
 * 函数复杂度分析结果接口
 */
export interface ComplexityResult {
  functionName: string;
  file: string;
  complexity: number;
  lineCount: number;
  suggestions: string[];
}

/**
 * 代码分析器类
 */
export class CodeAnalyzer {
  private minBlockSize: number;
  private similarityThreshold: number;

  /**
   * 构造函数
   * @param minBlockSize - 最小代码块大小
   * @param similarityThreshold - 相似度阈值
   */
  constructor(minBlockSize: number = 5, similarityThreshold: number = 0.8) {
    this.minBlockSize = minBlockSize;
    this.similarityThreshold = similarityThreshold;
  }

  /**
   * 分析目录中的重复代码
   * @param directory - 目录路径
   * @param extensions - 文件扩展名
   * @returns 重复代码检测结果
   */
  public async analyzeDuplicateCode(
    directory: string,
    extensions: string[] = ['.ts', '.tsx', '.js', '.jsx']
  ): Promise<DuplicateCodeResult[]> {
    const files = await this.getFiles(directory, extensions);
    const codeBlocks: CodeBlock[] = [];

    // 提取所有代码块
    for (const file of files) {
      const blocks = await this.extractCodeBlocks(file);
      codeBlocks.push(...blocks);
    }

    // 检测重复代码
    return this.findDuplicates(codeBlocks);
  }

  /**
   * 分析函数复杂度
   * @param directory - 目录路径
   * @param extensions - 文件扩展名
   * @returns 复杂度分析结果
   */
  public async analyzeComplexity(
    directory: string,
    extensions: string[] = ['.ts', '.tsx', '.js', '.jsx']
  ): Promise<ComplexityResult[]> {
    const files = await this.getFiles(directory, extensions);
    const results: ComplexityResult[] = [];

    for (const file of files) {
      const functions = await this.extractFunctions(file);
      for (const func of functions) {
        const complexity = this.calculateComplexity(func.content);
        const lineCount = func.content.split('\n').length;

        if (complexity > 10 || lineCount > 50) {
          results.push({
            functionName: func.name,
            file,
            complexity,
            lineCount,
            suggestions: this.generateComplexitySuggestions(complexity, lineCount),
          });
        }
      }
    }

    return results;
  }

  /**
   * 获取指定目录下的所有文件
   * @param directory - 目录路径
   * @param extensions - 文件扩展名
   * @returns 文件路径数组
   */
  private async getFiles(directory: string, extensions: string[]): Promise<string[]> {
    const files: string[] = [];

    const scanDirectory = async (dir: string): Promise<void> => {
      const entries = await fs.promises.readdir(dir, { withFileTypes: true });

      for (const entry of entries) {
        const fullPath = path.join(dir, entry.name);

        if (entry.isDirectory()) {
          // 跳过 node_modules 和其他不需要的目录
          if (!['node_modules', '.git', 'dist', 'build'].includes(entry.name)) {
            await scanDirectory(fullPath);
          }
        } else if (extensions.some(ext => entry.name.endsWith(ext))) {
          files.push(fullPath);
        }
      }
    };

    await scanDirectory(directory);
    return files;
  }

  /**
   * 提取文件中的代码块
   * @param filePath - 文件路径
   * @returns 代码块数组
   */
  private async extractCodeBlocks(filePath: string): Promise<CodeBlock[]> {
    const content = await fs.promises.readFile(filePath, 'utf-8');
    const lines = content.split('\n');
    const blocks: CodeBlock[] = [];

    for (let i = 0; i <= lines.length - this.minBlockSize; i++) {
      const blockLines = lines.slice(i, i + this.minBlockSize);
      const blockContent = blockLines.join('\n').trim();

      // 跳过空行和注释块
      if (this.isValidCodeBlock(blockContent)) {
        blocks.push({
          content: blockContent,
          file: filePath,
          startLine: i + 1,
          endLine: i + this.minBlockSize,
          hash: this.generateHash(blockContent),
        });
      }
    }

    return blocks;
  }

  /**
   * 提取文件中的函数
   * @param filePath - 文件路径
   * @returns 函数信息数组
   */
  private async extractFunctions(filePath: string): Promise<Array<{ name: string; content: string }>> {
    const content = await fs.promises.readFile(filePath, 'utf-8');
    const functions: Array<{ name: string; content: string }> = [];

    // 简单的函数提取正则表达式
    const functionRegex = /(?:function\s+(\w+)|const\s+(\w+)\s*=\s*(?:async\s+)?(?:\([^)]*\)\s*=>|\([^)]*\)\s*:\s*[^=]*=>)|(\w+)\s*\([^)]*\)\s*{)/g;
    let match;

    while ((match = functionRegex.exec(content)) !== null) {
      const functionName = match[1] || match[2] || match[3];
      const startIndex = match.index;
      
      // 找到函数的结束位置
      const functionContent = this.extractFunctionBody(content, startIndex);
      
      if (functionContent) {
        functions.push({
          name: functionName,
          content: functionContent,
        });
      }
    }

    return functions;
  }

  /**
   * 提取函数体内容
   * @param content - 文件内容
   * @param startIndex - 开始位置
   * @returns 函数体内容
   */
  private extractFunctionBody(content: string, startIndex: number): string | null {
    let braceCount = 0;
    let inFunction = false;
    let functionStart = startIndex;
    
    for (let i = startIndex; i < content.length; i++) {
      const char = content[i];
      
      if (char === '{') {
        if (!inFunction) {
          inFunction = true;
          functionStart = i;
        }
        braceCount++;
      } else if (char === '}') {
        braceCount--;
        if (inFunction && braceCount === 0) {
          return content.substring(functionStart, i + 1);
        }
      }
    }
    
    return null;
  }

  /**
   * 检测重复代码
   * @param blocks - 代码块数组
   * @returns 重复代码检测结果
   */
  private findDuplicates(blocks: CodeBlock[]): DuplicateCodeResult[] {
    const duplicates: DuplicateCodeResult[] = [];
    const processed = new Set<string>();

    for (let i = 0; i < blocks.length; i++) {
      if (processed.has(blocks[i].hash)) continue;

      const similarBlocks = [blocks[i]];
      
      for (let j = i + 1; j < blocks.length; j++) {
        const similarity = this.calculateSimilarity(blocks[i].content, blocks[j].content);
        
        if (similarity >= this.similarityThreshold) {
          similarBlocks.push(blocks[j]);
          processed.add(blocks[j].hash);
        }
      }

      if (similarBlocks.length > 1) {
        duplicates.push({
          blocks: similarBlocks,
          similarity: this.calculateAverageSimilarity(similarBlocks),
          suggestions: this.generateDuplicateSuggestions(similarBlocks),
        });
      }

      processed.add(blocks[i].hash);
    }

    return duplicates;
  }

  /**
   * 计算代码相似度
   * @param code1 - 代码1
   * @param code2 - 代码2
   * @returns 相似度（0-1）
   */
  private calculateSimilarity(code1: string, code2: string): number {
    // 简化的相似度计算
    const normalized1 = this.normalizeCode(code1);
    const normalized2 = this.normalizeCode(code2);
    
    if (normalized1 === normalized2) return 1;
    
    const longer = normalized1.length > normalized2.length ? normalized1 : normalized2;
    const shorter = normalized1.length > normalized2.length ? normalized2 : normalized1;
    
    if (longer.length === 0) return 1;
    
    const editDistance = this.levenshteinDistance(longer, shorter);
    return (longer.length - editDistance) / longer.length;
  }

  /**
   * 标准化代码（移除空白字符和注释）
   * @param code - 原始代码
   * @returns 标准化后的代码
   */
  private normalizeCode(code: string): string {
    return code
      .replace(/\/\*[\s\S]*?\*\//g, '') // 移除块注释
      .replace(/\/\/.*$/gm, '') // 移除行注释
      .replace(/\s+/g, ' ') // 标准化空白字符
      .trim();
  }

  /**
   * 计算编辑距离
   * @param str1 - 字符串1
   * @param str2 - 字符串2
   * @returns 编辑距离
   */
  private levenshteinDistance(str1: string, str2: string): number {
    const matrix = Array(str2.length + 1).fill(null).map(() => Array(str1.length + 1).fill(null));
    
    for (let i = 0; i <= str1.length; i++) matrix[0][i] = i;
    for (let j = 0; j <= str2.length; j++) matrix[j][0] = j;
    
    for (let j = 1; j <= str2.length; j++) {
      for (let i = 1; i <= str1.length; i++) {
        const indicator = str1[i - 1] === str2[j - 1] ? 0 : 1;
        matrix[j][i] = Math.min(
          matrix[j][i - 1] + 1, // deletion
          matrix[j - 1][i] + 1, // insertion
          matrix[j - 1][i - 1] + indicator // substitution
        );
      }
    }
    
    return matrix[str2.length][str1.length];
  }

  /**
   * 计算平均相似度
   * @param blocks - 代码块数组
   * @returns 平均相似度
   */
  private calculateAverageSimilarity(blocks: CodeBlock[]): number {
    if (blocks.length < 2) return 1;
    
    let totalSimilarity = 0;
    let comparisons = 0;
    
    for (let i = 0; i < blocks.length; i++) {
      for (let j = i + 1; j < blocks.length; j++) {
        totalSimilarity += this.calculateSimilarity(blocks[i].content, blocks[j].content);
        comparisons++;
      }
    }
    
    return comparisons > 0 ? totalSimilarity / comparisons : 1;
  }

  /**
   * 计算函数复杂度
   * @param functionContent - 函数内容
   * @returns 复杂度值
   */
  private calculateComplexity(functionContent: string): number {
    let complexity = 1; // 基础复杂度
    
    // 计算控制流语句
    const controlFlowPatterns = [
      /\bif\b/g,
      /\belse\s+if\b/g,
      /\bwhile\b/g,
      /\bfor\b/g,
      /\bswitch\b/g,
      /\bcase\b/g,
      /\bcatch\b/g,
      /\b&&\b/g,
      /\b\|\|\b/g,
      /\?\s*.*?\s*:/g, // 三元操作符
    ];
    
    for (const pattern of controlFlowPatterns) {
      const matches = functionContent.match(pattern);
      if (matches) {
        complexity += matches.length;
      }
    }
    
    return complexity;
  }

  /**
   * 生成重复代码优化建议
   * @param blocks - 重复代码块
   * @returns 优化建议
   */
  private generateDuplicateSuggestions(blocks: CodeBlock[]): string[] {
    const suggestions = [
      '考虑将重复代码提取为公共函数',
      '可以创建一个工具类来封装这些逻辑',
      '使用高阶组件或自定义Hook来复用逻辑',
    ];
    
    if (blocks.some(block => block.file.includes('component'))) {
      suggestions.push('考虑创建可复用的组件');
    }
    
    if (blocks.some(block => block.content.includes('useState') || block.content.includes('useEffect'))) {
      suggestions.push('考虑创建自定义Hook来封装状态逻辑');
    }
    
    return suggestions;
  }

  /**
   * 生成复杂度优化建议
   * @param complexity - 复杂度值
   * @param lineCount - 行数
   * @returns 优化建议
   */
  private generateComplexitySuggestions(complexity: number, lineCount: number): string[] {
    const suggestions: string[] = [];
    
    if (complexity > 15) {
      suggestions.push('函数复杂度过高，建议拆分为多个小函数');
    } else if (complexity > 10) {
      suggestions.push('考虑简化条件逻辑或提取部分逻辑到独立函数');
    }
    
    if (lineCount > 100) {
      suggestions.push('函数过长，建议拆分为多个职责单一的函数');
    } else if (lineCount > 50) {
      suggestions.push('考虑将部分逻辑提取到辅助函数中');
    }
    
    suggestions.push('考虑使用策略模式来简化复杂的条件逻辑');
    suggestions.push('可以使用配置对象来减少参数数量');
    
    return suggestions;
  }

  /**
   * 检查是否为有效的代码块
   * @param content - 代码内容
   * @returns 是否有效
   */
  private isValidCodeBlock(content: string): boolean {
    // 跳过空内容
    if (!content.trim()) return false;
    
    // 跳过纯注释块
    const withoutComments = content
      .replace(/\/\*[\s\S]*?\*\//g, '')
      .replace(/\/\/.*$/gm, '')
      .trim();
    
    if (!withoutComments) return false;
    
    // 跳过只有导入语句的块
    const lines = withoutComments.split('\n').filter(line => line.trim());
    const importLines = lines.filter(line => line.trim().startsWith('import'));
    
    return importLines.length < lines.length * 0.8;
  }

  /**
   * 生成内容哈希
   * @param content - 内容
   * @returns 哈希值
   */
  private generateHash(content: string): string {
    const normalized = this.normalizeCode(content);
    let hash = 0;
    
    for (let i = 0; i < normalized.length; i++) {
      const char = normalized.charCodeAt(i);
      hash = ((hash << 5) - hash) + char;
      hash = hash & hash; // 转换为32位整数
    }
    
    return hash.toString(36);
  }
}