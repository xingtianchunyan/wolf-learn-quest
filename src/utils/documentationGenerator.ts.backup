/**
 * 文档生成工具
 * 自动为组件和函数生成JSDoc注释
 * @author AI Assistant
 * @version 1.0.0
 */

import { promises as fs } from 'fs';
import path from 'path';

/**
 * 文档生成器配置接口
 */
interface DocumentationConfig {
  /** 源代码目录 */
  srcDir: string;
  /** 输出目录 */
  outputDir: string;
  /** 是否包含私有成员 */
  includePrivate: boolean;
  /** 是否生成示例代码 */
  includeExamples: boolean;
}

/**
 * 组件信息接口
 */
interface ComponentInfo {
  /** 组件名称 */
  name: string;
  /** 文件路径 */
  filePath: string;
  /** 组件描述 */
  description: string;
  /** 属性列表 */
  props: PropInfo[];
  /** 是否有文档 */
  hasDocumentation: boolean;
}

/**
 * 属性信息接口
 */
interface PropInfo {
  /** 属性名称 */
  name: string;
  /** 属性类型 */
  type: string;
  /** 是否必需 */
  required: boolean;
  /** 默认值 */
  defaultValue?: string;
  /** 属性描述 */
  description?: string;
}

/**
 * 函数信息接口
 */
interface FunctionInfo {
  /** 函数名称 */
  name: string;
  /** 函数描述 */
  description: string;
  /** 参数列表 */
  parameters: ParameterInfo[];
  /** 返回类型 */
  returnType: string;
  /** 返回值描述 */
  returnDescription: string;
}

/**
 * 参数信息接口
 */
interface ParameterInfo {
  /** 参数名称 */
  name: string;
  /** 参数类型 */
  type: string;
  /** 是否可选 */
  optional: boolean;
  /** 参数描述 */
  description: string;
}

/**
 * 文档生成器类
 * 负责分析代码并生成文档
 */
export class DocumentationGenerator {
  private config: DocumentationConfig;
  private components: ComponentInfo[] = [];
  private functions: FunctionInfo[] = [];

  /**
   * 构造函数
   * @param config - 文档生成器配置
   */
  constructor(config: Partial<DocumentationConfig> = {}) {
    this.config = {
      srcDir: config.srcDir || 'src',
      outputDir: config.outputDir || 'docs',
      includePrivate: config.includePrivate || false,
      includeExamples: config.includeExamples || true
    };
  }

  /**
   * 生成项目文档
   * @returns Promise<void>
   */
  async generateDocumentation(): Promise<void> {
    console.log('🚀 开始生成项目文档...');

    try {
      // 1. 扫描源代码文件
      await this.scanSourceFiles();

      // 2. 分析组件
      await this.analyzeComponents();

      // 3. 分析函数
      await this.analyzeFunctions();

      // 4. 生成文档文件
      await this.generateDocumentationFiles();

      // 5. 生成README
      await this.generateReadme();

      console.log('✅ 文档生成完成！');
    } catch (error) {
      console.error('❌ 文档生成失败:', error);
      throw error;
    }
  }

  /**
   * 扫描源代码文件
   * @private
   */
  private async scanSourceFiles(): Promise<void> {
    console.log('📁 扫描源代码文件...');

    const files = await this.getAllFiles(this.config.srcDir);
    const tsFiles = files.filter(file => 
      file.endsWith('.ts') || file.endsWith('.tsx')
    );

    console.log(`  发现 ${tsFiles.length} 个TypeScript文件`);
  }

  /**
   * 分析组件
   * @private
   */
  private async analyzeComponents(): Promise<void> {
    console.log('🧩 分析React组件...');

    const componentFiles = await this.getComponentFiles();
    
    for (const file of componentFiles) {
      const componentInfo = await this.analyzeComponent(file);
      if (componentInfo) {
        this.components.push(componentInfo);
      }
    }

    console.log(`  分析了 ${this.components.length} 个组件`);
  }

  /**
   * 分析单个组件
   * @param filePath - 组件文件路径
   * @returns Promise<ComponentInfo | null>
   * @private
   */
  private async analyzeComponent(filePath: string): Promise<ComponentInfo | null> {
    try {
      const content = await fs.readFile(filePath, 'utf-8');
      const componentName = this.extractComponentName(filePath, content);
      
      if (!componentName) return null;

      const props = this.extractProps(content);
      const hasDocumentation = this.hasJSDocComment(content);
      
      return {
        name: componentName,
        filePath: path.relative(this.config.srcDir, filePath),
        description: this.generateComponentDescription(componentName),
        props,
        hasDocumentation
      };
    } catch (error) {
      console.warn(`⚠️  无法分析组件 ${filePath}:`, error);
      return null;
    }
  }

  /**
   * 分析函数
   * @private
   */
  private async analyzeFunctions(): Promise<void> {
    console.log('🔧 分析工具函数...');

    const utilFiles = await this.getUtilFiles();
    
    for (const file of utilFiles) {
      const functions = await this.extractFunctions(file);
      this.functions.push(...functions);
    }

    console.log(`  分析了 ${this.functions.length} 个函数`);
  }

  /**
   * 提取组件名称
   * @param filePath - 文件路径
   * @param content - 文件内容
   * @returns string | null
   * @private
   */
  private extractComponentName(filePath: string, content: string): string | null {
    // 从文件名提取
    const fileName = path.basename(filePath, path.extname(filePath));
    
    // 检查是否是React组件
    if (content.includes('export default') && 
        (content.includes('function') || content.includes('const') || content.includes('class'))) {
      return fileName;
    }

    return null;
  }

  /**
   * 提取组件属性
   * @param content - 文件内容
   * @returns PropInfo[]
   * @private
   */
  private extractProps(content: string): PropInfo[] {
    const props: PropInfo[] = [];
    
    // 简单的props提取逻辑
    const interfaceMatch = content.match(/interface\s+\w*Props\s*{([^}]+)}/);
    if (interfaceMatch) {
      const propsContent = interfaceMatch[1];
      const propLines = propsContent.split('\n').filter(line => line.trim());
      
      for (const line of propLines) {
        const propMatch = line.match(/(\w+)(\?)?:\s*([^;]+)/);
        if (propMatch) {
          props.push({
            name: propMatch[1],
            type: propMatch[3].trim(),
            required: !propMatch[2],
            description: `${propMatch[1]} 属性`
          });
        }
      }
    }

    return props;
  }

  /**
   * 检查是否有JSDoc注释
   * @param content - 文件内容
   * @returns boolean
   * @private
   */
  private hasJSDocComment(content: string): boolean {
    return content.includes('/**') && content.includes('*/');
  }

  /**
   * 生成组件描述
   * @param componentName - 组件名称
   * @returns string
   * @private
   */
  private generateComponentDescription(componentName: string): string {
    // 基于组件名称生成描述
    const descriptions: Record<string, string> = {
      'Button': '通用按钮组件',
      'Input': '输入框组件',
      'Modal': '模态框组件',
      'Dialog': '对话框组件',
      'Form': '表单组件',
      'Table': '表格组件',
      'Card': '卡片组件',
      'Layout': '布局组件',
      'Header': '页头组件',
      'Footer': '页脚组件',
      'Sidebar': '侧边栏组件',
      'Navigation': '导航组件',
      'Menu': '菜单组件',
      'Loading': '加载组件',
      'Error': '错误显示组件',
      'Game': '游戏相关组件',
      'Player': '玩家相关组件',
      'Room': '房间相关组件',
      'Chat': '聊天相关组件',
      'Vote': '投票相关组件',
      'Skill': '技能相关组件',
      'Role': '角色相关组件',
      'Debug': '调试相关组件',
      'Admin': '管理相关组件',
      'Performance': '性能相关组件',
      'Monitor': '监控相关组件'
    };

    for (const [key, desc] of Object.entries(descriptions)) {
      if (componentName.includes(key)) {
        return desc;
      }
    }

    return `${componentName} 组件`;
  }

  /**
   * 获取所有文件
   * @param dir - 目录路径
   * @returns Promise<string[]>
   * @private
   */
  private async getAllFiles(dir: string): Promise<string[]> {
    const files: string[] = [];
    
    const scanDir = async (currentDir: string) => {
      try {
        const entries = await fs.readdir(currentDir, { withFileTypes: true });
        
        for (const entry of entries) {
          const fullPath = path.join(currentDir, entry.name);
          
          if (entry.isDirectory() && 
              !['node_modules', '.git', 'dist', 'build'].includes(entry.name)) {
            await scanDir(fullPath);
          } else if (entry.isFile()) {
            files.push(fullPath);
          }
        }
      } catch (error) {
        // 忽略无法访问的目录
      }
    };
    
    await scanDir(dir);
    return files;
  }

  /**
   * 获取组件文件
   * @returns Promise<string[]>
   * @private
   */
  private async getComponentFiles(): Promise<string[]> {
    const allFiles = await this.getAllFiles(this.config.srcDir);
    return allFiles.filter(file => 
      file.endsWith('.tsx') && 
      (file.includes('/components/') || file.includes('/pages/'))
    );
  }

  /**
   * 获取工具函数文件
   * @returns Promise<string[]>
   * @private
   */
  private async getUtilFiles(): Promise<string[]> {
    const allFiles = await this.getAllFiles(this.config.srcDir);
    return allFiles.filter(file => 
      file.endsWith('.ts') && 
      file.includes('/utils/')
    );
  }

  /**
   * 提取函数信息
   * @param filePath - 文件路径
   * @returns Promise<FunctionInfo[]>
   * @private
   */
  private async extractFunctions(filePath: string): Promise<FunctionInfo[]> {
    try {
      const content = await fs.readFile(filePath, 'utf-8');
      const functions: FunctionInfo[] = [];
      
      // 简单的函数提取逻辑
      const functionMatches = content.matchAll(/export\s+(?:async\s+)?function\s+(\w+)/g);
      
      for (const match of functionMatches) {
        const functionName = match[1];
        functions.push({
          name: functionName,
          description: `${functionName} 函数`,
          parameters: [],
          returnType: 'unknown',
          returnDescription: '函数返回值'
        });
      }

      return functions;
    } catch (error) {
      console.warn(`⚠️  无法分析函数 ${filePath}:`, error);
      return [];
    }
  }

  /**
   * 生成文档文件
   * @private
   */
  private async generateDocumentationFiles(): Promise<void> {
    console.log('📝 生成文档文件...');

    // 确保输出目录存在
    await fs.mkdir(this.config.outputDir, { recursive: true });

    // 生成组件文档
    await this.generateComponentDocs();

    // 生成函数文档
    await this.generateFunctionDocs();

    // 生成API文档
    await this.generateApiDocs();
  }

  /**
   * 生成组件文档
   * @private
   */
  private async generateComponentDocs(): Promise<void> {
    const componentDocsDir = path.join(this.config.outputDir, 'components');
    await fs.mkdir(componentDocsDir, { recursive: true });

    for (const component of this.components) {
      const docContent = this.generateComponentDocContent(component);
      const docPath = path.join(componentDocsDir, `${component.name}.md`);
      await fs.writeFile(docPath, docContent);
    }

    console.log(`  生成了 ${this.components.length} 个组件文档`);
  }

  /**
   * 生成组件文档内容
   * @param component - 组件信息
   * @returns string
   * @private
   */
  private generateComponentDocContent(component: ComponentInfo): string {
    let content = `# ${component.name}\n\n`;
    content += `${component.description}\n\n`;
    content += `## 文件位置\n\n\`${component.filePath}\`\n\n`;
    
    if (component.props.length > 0) {
      content += `## 属性\n\n`;
      content += `| 属性名 | 类型 | 必需 | 默认值 | 描述 |\n`;
      content += `|--------|------|------|--------|------|\n`;
      
      for (const prop of component.props) {
        content += `| ${prop.name} | \`${prop.type}\` | ${prop.required ? '是' : '否'} | ${prop.defaultValue || '-'} | ${prop.description || '-'} |\n`;
      }
      content += '\n';
    }

    if (this.config.includeExamples) {
      content += `## 使用示例\n\n`;
      content += `\`\`\`tsx\n`;
      content += `import ${component.name} from './${component.filePath.replace('.tsx', '')}';\n\n`;
      content += `function Example() {\n`;
      content += `  return (\n`;
      content += `    <${component.name}`;
      
      if (component.props.length > 0) {
        content += `\n`;
        for (const prop of component.props.slice(0, 3)) {
          if (prop.required) {
            content += `      ${prop.name}={/* ${prop.description} */}\n`;
          }
        }
        content += `    `;
      }
      
      content += ` />\n`;
      content += `  );\n`;
      content += `}\n`;
      content += `\`\`\`\n\n`;
    }

    content += `## 文档状态\n\n`;
    content += `- 有JSDoc注释: ${component.hasDocumentation ? '✅' : '❌'}\n`;
    content += `- 最后更新: ${new Date().toLocaleDateString()}\n`;

    return content;
  }

  /**
   * 生成函数文档
   * @private
   */
  private async generateFunctionDocs(): Promise<void> {
    const functionDocsDir = path.join(this.config.outputDir, 'functions');
    await fs.mkdir(functionDocsDir, { recursive: true });

    let content = `# 工具函数文档\n\n`;
    content += `本文档包含项目中所有工具函数的说明。\n\n`;

    for (const func of this.functions) {
      content += `## ${func.name}\n\n`;
      content += `${func.description}\n\n`;
      
      if (func.parameters.length > 0) {
        content += `### 参数\n\n`;
        for (const param of func.parameters) {
          content += `- **${param.name}** (\`${param.type}\`${param.optional ? ', 可选' : ''}): ${param.description}\n`;
        }
        content += '\n';
      }

      content += `### 返回值\n\n`;
      content += `\`${func.returnType}\` - ${func.returnDescription}\n\n`;
      content += '---\n\n';
    }

    const docPath = path.join(functionDocsDir, 'index.md');
    await fs.writeFile(docPath, content);

    console.log(`  生成了函数文档`);
  }

  /**
   * 生成API文档
   * @private
   */
  private async generateApiDocs(): Promise<void> {
    const apiDocsDir = path.join(this.config.outputDir, 'api');
    await fs.mkdir(apiDocsDir, { recursive: true });

    const content = `# API 文档\n\n`;
    // TODO: 实现API文档生成逻辑

    const docPath = path.join(apiDocsDir, 'index.md');
    await fs.writeFile(docPath, content);

    console.log(`  生成了API文档`);
  }

  /**
   * 生成README
   * @private
   */
  private async generateReadme(): Promise<void> {
    console.log('📖 生成README文档...');

    const readmeContent = this.generateReadmeContent();
    const readmePath = path.join(this.config.outputDir, 'README.md');
    await fs.writeFile(readmePath, readmeContent);

    console.log(`  README文档已生成: ${readmePath}`);
  }

  /**
   * 生成README内容
   * @returns string
   * @private
   */
  private generateReadmeContent(): string {
    let content = `# 项目文档\n\n`;
    content += `本文档由文档生成器自动生成，包含项目的组件、函数和API说明。\n\n`;
    
    content += `## 项目概览\n\n`;
    content += `- 组件总数: ${this.components.length}\n`;
    content += `- 工具函数: ${this.functions.length}\n`;
    content += `- 文档覆盖率: ${this.calculateDocumentationCoverage()}%\n\n`;

    content += `## 目录结构\n\n`;
    content += `- [组件文档](./components/) - 所有React组件的详细说明\n`;
    content += `- [函数文档](./functions/) - 工具函数和帮助函数说明\n`;
    content += `- [API文档](./api/) - 接口和API端点说明\n\n`;

    content += `## 组件列表\n\n`;
    for (const component of this.components.slice(0, 20)) {
      const status = component.hasDocumentation ? '✅' : '❌';
      content += `- [${component.name}](./components/${component.name}.md) ${status}\n`;
    }
    
    if (this.components.length > 20) {
      content += `- ... 还有 ${this.components.length - 20} 个组件\n`;
    }
    content += '\n';

    content += `## 开发指南\n\n`;
    content += `### 添加组件文档\n\n`;
    content += `为组件添加JSDoc注释：\n\n`;
    content += `\`\`\`tsx\n`;
    content += `/**\n`;
    content += ` * 组件描述\n`;
    content += ` * @param props - 组件属性\n`;
    content += ` * @returns JSX元素\n`;
    content += ` */\n`;
    content += `function MyComponent(props: MyComponentProps) {\n`;
    content += `  // 组件实现\n`;
    content += `}\n`;
    content += `\`\`\`\n\n`;

    content += `### 更新文档\n\n`;
    content += `运行以下命令重新生成文档：\n\n`;
    content += `\`\`\`bash\n`;
    content += `npm run docs:generate\n`;
    content += `\`\`\`\n\n`;

    content += `---\n\n`;
    content += `*文档生成时间: ${new Date().toLocaleString()}*\n`;

    return content;
  }

  /**
   * 计算文档覆盖率
   * @returns number
   * @private
   */
  private calculateDocumentationCoverage(): number {
    if (this.components.length === 0) return 0;
    
    const documentedComponents = this.components.filter(c => c.hasDocumentation).length;
    return Math.round((documentedComponents / this.components.length) * 100);
  }

  /**
   * 获取统计信息
   * @returns 文档统计信息
   */
  getStatistics() {
    return {
      totalComponents: this.components.length,
      documentedComponents: this.components.filter(c => c.hasDocumentation).length,
      totalFunctions: this.functions.length,
      documentationCoverage: this.calculateDocumentationCoverage()
    };
  }
}

/**
 * 默认导出文档生成器类
 */
export default DocumentationGenerator;