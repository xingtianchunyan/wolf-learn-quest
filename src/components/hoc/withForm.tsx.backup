/**
 * 文件级注释：表单高阶组件
 * 为组件添加统一的表单处理功能
 */

import React from 'react';
import { useForm, FormConfig, FormState, FormActions } from '@/hooks/shared/useForm';
import { withLoading, WithLoadingProps } from './withLoading';
import { withErrorBoundary } from './withErrorBoundary';

/**
 * 表单高阶组件属性接口
 */
export interface WithFormProps<T extends Record<string, any> = Record<string, any>> {
  formConfig?: FormConfig<T>;
  onFormSubmit?: (values: T) => Promise<void> | void;
  onFormChange?: (values: T, changedField: keyof T) => void;
  onFormError?: (errors: Record<keyof T, string>) => void;
}

/**
 * 注入的表单属性接口
 */
export interface InjectedFormProps<T extends Record<string, any> = Record<string, any>> {
  formState: FormState<T>;
  formActions: FormActions<T>;
}

/**
 * 表单高阶组件
 * 为组件添加统一的表单处理功能
 * @param WrappedComponent - 被包装的组件
 * @param defaultConfig - 默认表单配置
 * @returns 带有表单功能的组件
 */
export function withForm<
  P extends object,
  T extends Record<string, any> = Record<string, any>
>(
  WrappedComponent: React.ComponentType<P & InjectedFormProps<T>>,
  defaultConfig?: FormConfig<T>
): React.FC<P & WithFormProps<T> & WithLoadingProps> {
  /**
   * 带表单功能的组件
   */
  const WithFormComponent: React.FC<P & WithFormProps<T> & WithLoadingProps> = (props) => {
    const {
      formConfig,
      onFormSubmit,
      onFormChange,
      onFormError,
      isLoading,
      loadingText,
      ...restProps
    } = props;

    // 合并配置
    const mergedConfig: FormConfig<T> = {
      ...defaultConfig,
      ...formConfig,
      onSubmit: onFormSubmit || formConfig?.onSubmit || defaultConfig?.onSubmit,
      onChange: onFormChange || formConfig?.onChange || defaultConfig?.onChange,
      onValidationError: onFormError || formConfig?.onValidationError || defaultConfig?.onValidationError,
    };

    // 使用表单Hook
    const [formState, formActions] = useForm<T>(mergedConfig);

    // 包装提交函数以显示加载状态
    const wrappedSubmit = React.useCallback(async () => {
      try {
        await formActions.submit();
      } catch (error) {
        console.error('表单提交失败:', error);
        throw error;
      }
    }, [formActions.submit]);

    // 注入表单状态和操作
    const injectedProps = {
      ...restProps,
      formState: {
        ...formState,
        submitting: formState.submitting || isLoading,
      },
      formActions: {
        ...formActions,
        submit: wrappedSubmit,
      },
    } as P & InjectedFormProps<T>;

    return <WrappedComponent {...injectedProps} />;
  };

  WithFormComponent.displayName = `withForm(${WrappedComponent.displayName || WrappedComponent.name})`;

  // 组合加载状态和错误边界
  return withErrorBoundary(
    withLoading(WithFormComponent),
    undefined,
    (error, errorInfo) => {
      console.error('表单组件错误:', error, errorInfo);
    }
  );
}

/**
 * 表单字段组件属性接口
 */
export interface FormFieldProps<T = any> {
  name: string;
  label?: string;
  placeholder?: string;
  required?: boolean;
  disabled?: boolean;
  className?: string;
  error?: string | null;
  value?: T;
  onChange?: (value: T) => void;
  onBlur?: () => void;
}

/**
 * 通用表单字段组件
 * 提供统一的表单字段渲染
 */
export const FormField: React.FC<FormFieldProps & {
  children: (props: FormFieldProps) => React.ReactNode;
}> = ({ children, ...props }) => {
  return (
    <div className="space-y-2">
      {props.label && (
        <label 
          htmlFor={props.name}
          className={`block text-sm font-medium text-gray-700 ${
            props.required ? "after:content-['*'] after:text-red-500 after:ml-1" : ''
          }`}
        >
          {props.label}
        </label>
      )}
      {children(props)}
      {props.error && (
        <p className="text-sm text-red-600" role="alert">
          {props.error}
        </p>
      )}
    </div>
  );
};

/**
 * 表单容器组件
 * 提供统一的表单布局和样式
 */
export interface FormContainerProps {
  title?: string;
  description?: string;
  children: React.ReactNode;
  onSubmit?: (e: React.FormEvent) => void;
  className?: string;
  loading?: boolean;
  disabled?: boolean;
}

/**
 * 表单容器组件
 */
export const FormContainer: React.FC<FormContainerProps> = ({
  title,
  description,
  children,
  onSubmit,
  className = '',
  loading = false,
  disabled = false,
}) => {
  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    if (!loading && !disabled && onSubmit) {
      onSubmit(e);
    }
  };

  return (
    <div className={`bg-white rounded-lg shadow-sm border p-6 ${className}`}>
      {(title || description) && (
        <div className="mb-6">
          {title && (
            <h2 className="text-xl font-semibold text-gray-900 mb-2">
              {title}
            </h2>
          )}
          {description && (
            <p className="text-gray-600">
              {description}
            </p>
          )}
        </div>
      )}
      
      <form onSubmit={handleSubmit} className="space-y-4">
        <fieldset disabled={loading || disabled}>
          {children}
        </fieldset>
      </form>
    </div>
  );
};

/**
 * 表单操作按钮组件
 */
export interface FormActionsProps {
  submitText?: string;
  cancelText?: string;
  onCancel?: () => void;
  loading?: boolean;
  disabled?: boolean;
  className?: string;
}

/**
 * 表单操作按钮组件
 */
export const FormActions: React.FC<FormActionsProps> = ({
  submitText = '提交',
  cancelText = '取消',
  onCancel,
  loading = false,
  disabled = false,
  className = '',
}) => {
  return (
    <div className={`flex justify-end space-x-3 pt-4 border-t ${className}`}>
      {onCancel && (
        <button
          type="button"
          onClick={onCancel}
          disabled={loading}
          className="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          {cancelText}
        </button>
      )}
      <button
        type="submit"
        disabled={loading || disabled}
        className="px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed flex items-center"
      >
        {loading && (
          <svg className="animate-spin -ml-1 mr-2 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
            <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4"></circle>
            <path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        )}
        {submitText}
      </button>
    </div>
  );
};