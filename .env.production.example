# 生产环境配置模板
# 复制此文件为 .env.production 并填入实际值

# 应用环境
NODE_ENV=production

# Supabase 配置（请替换为新的 Supabase 项目信息）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# 应用配置
VITE_APP_NAME=Wolf Learn Quest
VITE_APP_VERSION=1.0.0
VITE_APP_URL=https://your-domain.com

# 安全配置
VITE_ENABLE_ANALYTICS=false
VITE_SENTRY_DSN=

# 功能开关
VITE_ENABLE_PWA=false
VITE_ENABLE_OFFLINE_MODE=false
VITE_ENABLE_PUSH_NOTIFICATIONS=false

# 性能配置
VITE_ENABLE_SERVICE_WORKER=false
VITE_CACHE_VERSION=1

# 监控配置
VITE_ENABLE_ERROR_REPORTING=false
VITE_ENABLE_PERFORMANCE_MONITORING=false

# API配置
VITE_API_TIMEOUT=30000
VITE_MAX_RETRY_ATTEMPTS=3

# 游戏配置
VITE_MAX_PLAYERS_PER_GAME=12
VITE_GAME_TIMEOUT_MINUTES=30
VITE_ENABLE_SPECTATOR_MODE=false

# 社交功能
VITE_ENABLE_CHAT=true
VITE_ENABLE_VOICE_CHAT=false
VITE_MAX_MESSAGE_LENGTH=500

# 文件上传
VITE_MAX_AVATAR_SIZE_MB=5
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# 缓存配置
VITE_CACHE_STRATEGY=stale-while-revalidate
VITE_CACHE_MAX_AGE=3600

# 第三方服务
VITE_GOOGLE_ANALYTICS_ID=
VITE_HOTJAR_ID=

# 开发工具（生产环境应设为 false）
VITE_ENABLE_DEVTOOLS=false
VITE_ENABLE_REDUX_DEVTOOLS=false
