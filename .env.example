# Supabase Configuration
# Copy this file to .env and fill in your actual values
# Get these values from your Supabase project dashboard

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id

# Supabase Edge Functions 部署时需要（通过 `supabase secrets set` 设置，不暴露给前端）
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SILICONFLOW_API_KEY=your_siliconflow_key

# E2E 测试账号（可选）
# 提供 SUPABASE_SERVICE_ROLE_KEY 时，测试会自动创建并确认以下账号。
# 如果不提供 service role key，项目必须关闭邮箱确认，或你已在 Supabase 中手动创建并确认以下账号。
# E2E_HOST_EMAIL=e2e-host@wolflearnquest-e2e.example.com
# E2E_HOST_PASSWORD=TestPass123!
# E2E_PLAYER_EMAIL=e2e-player@wolflearnquest-e2e.example.com
# E2E_PLAYER_PASSWORD=TestPass123!